# Managed by Ansible (siyuan role).
# Publishes the SiYuan sync WebDAV on the tailnet for the mobile app.
server {
    listen {{ siyuan_native_bind }}:{{ siyuan_sync_port }};
    access_log /var/log/nginx/siyuan-sync.log;
    location / {
        proxy_pass http://127.0.0.1:{{ siyuan_sync_port }};
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        client_max_body_size 0;
        proxy_read_timeout 300;
        proxy_request_buffering off;
    }
}
