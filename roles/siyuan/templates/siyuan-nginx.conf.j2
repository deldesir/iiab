# SiYuan Nginx Reverse Proxy
# Managed by Ansible — edit via /etc/iiab/local_vars.yml

location /siyuan/ {
    proxy_pass http://127.0.0.1:{{ siyuan_port }}/;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;

    # WebSocket support (required for SiYuan real-time editing)
    proxy_http_version 1.1;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection "upgrade";

    proxy_read_timeout 300s;
    proxy_connect_timeout 10s;

    # SiYuan uses large payloads for notebook sync
    client_max_body_size 512M;
}

# WebSocket endpoint
location /siyuan/ws {
    proxy_pass http://127.0.0.1:{{ siyuan_port }}/ws;
    proxy_http_version 1.1;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection "upgrade";
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_read_timeout 86400s;
}
