# SiYuan Nginx Reverse Proxy (subpath at /siyuan/)
# Managed by Ansible — edit via /etc/iiab/local_vars.yml

# Main entry point
location /siyuan/ {
    proxy_pass http://127.0.0.1:{{ siyuan_port }}/;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_http_version 1.1;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection "upgrade";
    proxy_read_timeout 300s;
    client_max_body_size 512M;

    # Rewrite SiYuan's internal paths in HTML/JS to include /siyuan/ prefix
    sub_filter_once off;
    sub_filter_types text/html application/javascript;

    sub_filter '"/check-auth/' '"/siyuan/check-auth/';
    sub_filter '"/api/' '"/siyuan/api/';
    sub_filter '"/ws/' '"/siyuan/ws/';
    sub_filter '"/ws?/' '"/siyuan/ws?/';
    sub_filter '"/stage/' '"/siyuan/stage/';
    sub_filter '"/assets/' '"/siyuan/assets/';
    sub_filter '"/appearance/' '"/siyuan/appearance/';
    sub_filter '"/snippets/' '"/siyuan/snippets/';
    sub_filter '"/plugins/' '"/siyuan/plugins/';
    sub_filter '"/widgets/' '"/siyuan/widgets/';
    sub_filter '"/emojis/' '"/siyuan/emojis/';
    sub_filter '"/export/' '"/siyuan/export/';
    sub_filter '"/service-worker.js/' '"/siyuan/service-worker.js/';
    sub_filter "'/check-auth/" "'/siyuan/check-auth/";
    sub_filter "'/api/" "'/siyuan/api/";
    sub_filter "'/ws/" "'/siyuan/ws/";
    sub_filter "'/ws?/" "'/siyuan/ws?/";
    sub_filter "'/stage/" "'/siyuan/stage/";
    sub_filter "'/assets/" "'/siyuan/assets/";
    sub_filter "'/appearance/" "'/siyuan/appearance/";
    sub_filter "'/snippets/" "'/siyuan/snippets/";
    sub_filter "'/plugins/" "'/siyuan/plugins/";
    sub_filter "'/widgets/" "'/siyuan/widgets/";
    sub_filter "'/emojis/" "'/siyuan/emojis/";
    sub_filter "'/export/" "'/siyuan/export/";
    sub_filter "'/service-worker.js/" "'/siyuan/service-worker.js/";
    sub_filter "`/check-auth/" "`/siyuan/check-auth/";
    sub_filter "`/api/" "`/siyuan/api/";
    sub_filter "`/ws/" "`/siyuan/ws/";
    sub_filter "`/ws?/" "`/siyuan/ws?/";
    sub_filter "`/stage/" "`/siyuan/stage/";
    sub_filter "`/assets/" "`/siyuan/assets/";
    sub_filter "`/appearance/" "`/siyuan/appearance/";
    sub_filter "`/snippets/" "`/siyuan/snippets/";
    sub_filter "`/plugins/" "`/siyuan/plugins/";
    sub_filter "`/widgets/" "`/siyuan/widgets/";
    sub_filter "`/emojis/" "`/siyuan/emojis/";
    sub_filter "`/export/" "`/siyuan/export/";
    sub_filter "`/service-worker.js/" "`/siyuan/service-worker.js/";
}


# SiYuan WebSocket — JS builds this URL dynamically without /siyuan/ prefix
location /ws {
    proxy_pass http://127.0.0.1:{{ siyuan_port }}/ws;
    proxy_http_version 1.1;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection "upgrade";
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_read_timeout 86400s;
}

# SiYuan check-auth page — JS redirects here without /siyuan/ prefix
# After auth, JS redirects to the "to" param. Rewrite it to /siyuan/.
location /check-auth {
    # Fix redirect target: ?to=/ or ?to=%2F → ?to=/siyuan/
    if ($arg_to = "/") {
        return 302 $scheme://$host/check-auth?to=/siyuan/;
    }
    if ($arg_to = "%2F") {
        return 302 $scheme://$host/check-auth?to=/siyuan/;
    }

    proxy_pass http://127.0.0.1:{{ siyuan_port }}/check-auth;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_http_version 1.1;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection "upgrade";

    sub_filter_once off;
    sub_filter_types text/html application/javascript;

    sub_filter '"/check-auth/' '"/siyuan/check-auth/';
    sub_filter '"/api/' '"/siyuan/api/';
    sub_filter '"/ws/' '"/siyuan/ws/';
    sub_filter '"/ws?/' '"/siyuan/ws?/';
    sub_filter '"/stage/' '"/siyuan/stage/';
    sub_filter '"/assets/' '"/siyuan/assets/';
    sub_filter '"/appearance/' '"/siyuan/appearance/';
    sub_filter '"/snippets/' '"/siyuan/snippets/';
    sub_filter '"/plugins/' '"/siyuan/plugins/';
    sub_filter '"/widgets/' '"/siyuan/widgets/';
    sub_filter '"/emojis/' '"/siyuan/emojis/';
    sub_filter '"/export/' '"/siyuan/export/';
    sub_filter '"/service-worker.js/' '"/siyuan/service-worker.js/';
    sub_filter "'/check-auth/" "'/siyuan/check-auth/";
    sub_filter "'/api/" "'/siyuan/api/";
    sub_filter "'/ws/" "'/siyuan/ws/";
    sub_filter "'/ws?/" "'/siyuan/ws?/";
    sub_filter "'/stage/" "'/siyuan/stage/";
    sub_filter "'/assets/" "'/siyuan/assets/";
    sub_filter "'/appearance/" "'/siyuan/appearance/";
    sub_filter "'/snippets/" "'/siyuan/snippets/";
    sub_filter "'/plugins/" "'/siyuan/plugins/";
    sub_filter "'/widgets/" "'/siyuan/widgets/";
    sub_filter "'/emojis/" "'/siyuan/emojis/";
    sub_filter "'/export/" "'/siyuan/export/";
    sub_filter "'/service-worker.js/" "'/siyuan/service-worker.js/";
    sub_filter "`/check-auth/" "`/siyuan/check-auth/";
    sub_filter "`/api/" "`/siyuan/api/";
    sub_filter "`/ws/" "`/siyuan/ws/";
    sub_filter "`/ws?/" "`/siyuan/ws?/";
    sub_filter "`/stage/" "`/siyuan/stage/";
    sub_filter "`/assets/" "`/siyuan/assets/";
    sub_filter "`/appearance/" "`/siyuan/appearance/";
    sub_filter "`/snippets/" "`/siyuan/snippets/";
    sub_filter "`/plugins/" "`/siyuan/plugins/";
    sub_filter "`/widgets/" "`/siyuan/widgets/";
    sub_filter "`/emojis/" "`/siyuan/emojis/";
    sub_filter "`/export/" "`/siyuan/export/";
    sub_filter "`/service-worker.js/" "`/siyuan/service-worker.js/";
}


# SiYuan API catch-all — regex with negative lookahead
# Catches ALL /api/* EXCEPT ERPNext (/api/method/, /api/resource/) and RapidPro (/api/v2/)
location ~ ^/api/(?!method/|resource/|v2/) {
    proxy_pass http://127.0.0.1:{{ siyuan_port }};
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
}

# Catch-all for SiYuan asset/page paths that JS/CSS reference without /siyuan/ prefix
location ~ ^/(stage|desktop|mobile|appearance|assets|snippets|plugins|widgets|emojis|export|service-worker\.js)(/|$) {
    proxy_pass http://127.0.0.1:{{ siyuan_port }};
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_http_version 1.1;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection "upgrade";
}
