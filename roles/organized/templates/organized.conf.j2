# Organized App Nginx Configuration
location /organized/api/ {
    proxy_pass http://127.0.0.1:{{ organized_port }}/api/;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
}

location /organized/ {
    alias {{ organized_app_dir }}/dist/;
    index index.html;
    try_files $uri $uri/ /organized/index.html;
}
