# Organized App Nginx Configuration
location /organized/api/ {
    proxy_pass http://127.0.0.1:{{ organized_port }}/api/;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
}

location /organized-sources/ {
    alias {{ organized_sources_dir }}/;
    default_type application/json;
    try_files $uri =404;
    add_header Cache-Control "no-cache";
}

# The PWA manifest must carry the correct MIME type for install prompts to
# work. `.webmanifest` is absent from nginx's default mime.types, so without
# this exact-match override it would be served as text/html. Exact (=) match
# wins over the /organized/ prefix below.
location = /organized/manifest.webmanifest {
    alias {{ organized_app_dir }}/dist/manifest.webmanifest;
    default_type application/manifest+json;
    add_header Cache-Control "no-cache";
}

location /organized/ {
    alias {{ organized_app_dir }}/dist/;
    index index.html;
    try_files $uri $uri/ /organized/index.html;
}
