# Managed by IIAB roles/organized — offline / self-hosted build config.
# Vite loads .env.production.local with the highest precedence in production
# builds, so these values win even if the cloned app repo ships its own
# .env.production (e.g. when built from an upstream checkout).
VITE_API_HOST=/organized
VITE_AUTH_MODE=local
VITE_SOURCE_MATERIALS_API={{ organized_source_materials_api }}
VITE_NOTIFICATIONS_API={{ organized_notifications_api }}
