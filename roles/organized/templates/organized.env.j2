DJANGO_SECRET_KEY='{{ organized_secret_key | default(django_secret_key.stdout) }}'
DJANGO_DEBUG=False
{# Include the public SSL domain (e.g. example.org) when IIAB SSL is on,
   mirroring roles/nginx server.conf.j2 — otherwise Django returns 400
   DisallowedHost for same-origin API calls made over https://<ssl_domain>/. #}
DJANGO_ALLOWED_HOSTS={{ iiab_hostname | default('box') }}.{{ iiab_domain | default('lan') }},127.0.0.1,localhost{% if iiab_ssl_enabled | default(False) | bool and (iiab_ssl_domain | default('box.lan')) != 'box.lan' %},{{ iiab_ssl_domain }}{% if iiab_ssl_www_resolved | default(False) | bool %},www.{{ iiab_ssl_domain }}{% endif %}{% endif %}
DB_NAME={{ organized_db_name }}
DB_USER={{ organized_db_user }}
DB_PASSWORD={{ organized_db_pass }}
CELERY_BROKER_URL=redis://127.0.0.1:6379/1
{# RapidPro's REST API is served by temba behind nginx — NOT by courier
   (which listens on :8080 and answers /api/v2/* with 404s), and temba
   direct on :8000 rejects requests missing the proxy headers. Default to
   the nginx front. Machine-local secrets/overrides (e.g. the API token)
   belong in /etc/iiab/organized.env.local — never written by Ansible and
   loaded after this file by the units, so its values win. #}
RAPIDPRO_URL={{ organized_rapidpro_url | default('https://' ~ iiab_ssl_domain if (iiab_ssl_enabled | default(False) | bool and (iiab_ssl_domain | default('box.lan')) != 'box.lan') else 'http://' ~ (iiab_hostname | default('box')) ~ '.' ~ (iiab_domain | default('lan'))) }}
RAPIDPRO_API_TOKEN={{ organized_rapidpro_token | default('') }}
ORGANIZED_NOTIFICATION_FLOW_UUID={{ organized_notification_flow_uuid | default('') }}
ORGANIZED_WEBHOOK_SECRET={{ organized_webhook_secret | default('') }}
# Comma-separated feature flags served to the PWA (no rebuild needed)
ORGANIZED_FEATURE_FLAGS={{ organized_feature_flags | default('HOURGLASS_IMPORT') }}
