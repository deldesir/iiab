DJANGO_SECRET_KEY='{{ organized_secret_key | default(django_secret_key.stdout) }}'
DJANGO_DEBUG=False
{# Include the public SSL domain (e.g. garantie.boutique) when IIAB SSL is on,
   mirroring roles/nginx server.conf.j2 — otherwise Django returns 400
   DisallowedHost for same-origin API calls made over https://<ssl_domain>/. #}
DJANGO_ALLOWED_HOSTS={{ iiab_hostname | default('box') }}.{{ iiab_domain | default('lan') }},127.0.0.1,localhost{% if iiab_ssl_enabled | default(False) | bool and (iiab_ssl_domain | default('box.lan')) != 'box.lan' %},{{ iiab_ssl_domain }}{% if iiab_ssl_www_resolved | default(False) | bool %},www.{{ iiab_ssl_domain }}{% endif %}{% endif %}
DB_NAME={{ organized_db_name }}
DB_USER={{ organized_db_user }}
DB_PASSWORD={{ organized_db_pass }}
CELERY_BROKER_URL=redis://127.0.0.1:6379/1
RAPIDPRO_URL=http://127.0.0.1:8080
RAPIDPRO_API_TOKEN={{ organized_rapidpro_token | default('') }}
ORGANIZED_NOTIFICATION_FLOW_UUID={{ organized_notification_flow_uuid | default('') }}
ORGANIZED_WEBHOOK_SECRET={{ organized_webhook_secret | default('') }}
