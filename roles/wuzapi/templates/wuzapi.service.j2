[Unit]
Description=Wuzapi Whatsapp API Service
After=network.target postgresql.service

[Service]
Type=simple
User={{ iiab_admin_user }}
Group={{ iiab_admin_user }}
WorkingDirectory={{ wuzapi_dir }}
ExecStart={{ wuzapi_dir }}/wuzapi -address 127.0.0.1 -port {{ wuzapi_port }} -logtype json -wadebug {{ wuzapi_debug }}
Restart=always
RestartSec=5
Environment=WUZAPI_ADMIN_TOKEN={{ wuzapi_admintoken }}
Environment=WUZAPI_GLOBAL_ENCRYPTION_KEY={{ wuzapi_global_encryption_key }}
Environment=WUZAPI_GLOBAL_HMAC_KEY={{ wuzapi_global_hmac_key }}

[Install]
WantedBy=multi-user.target
