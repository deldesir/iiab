# Nginx configuration for Bagisto inside IIAB

{% if bagisto_headless_enabled | default(False) %}
# ----------------------------------------------------
# HEADLESS MODE (Next.js Proxied Front, PHP Backend)
# ----------------------------------------------------

location ^~ {{ bagisto_app_url }}/admin {
    alias {{ bagisto_abs_path }}/public/admin;
    try_files $uri $uri/ @bagisto;
    location ~ \.php$ {
        include fastcgi_params;
        fastcgi_pass php;
        fastcgi_param SCRIPT_FILENAME $request_filename;
        fastcgi_param SCRIPT_NAME {{ bagisto_app_url }}/index.php;
        fastcgi_hide_header X-Powered-By;
    }
}

location ^~ {{ bagisto_app_url }}/api {
    try_files $uri $uri/ @bagisto;
}

location ^~ {{ bagisto_app_url }}/graphql {
    try_files $uri $uri/ @bagisto;
}

location ^~ {{ bagisto_app_url }} {
    proxy_pass http://127.0.0.1:{{ bagisto_headless_port | default(3000) }};
    proxy_http_version 1.1;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection 'upgrade';
    proxy_set_header Host $host;
    proxy_cache_bypass $http_upgrade;
}

{% else %}
# ----------------------------------------------------
# MONOLITHIC MODE (Standard Laravel/Livewire PHP Front)
# ----------------------------------------------------

location ^~ {{ bagisto_app_url }} {
    alias {{ bagisto_abs_path }}/public;
    index index.php index.html index.htm;

    add_header X-Frame-Options "SAMEORIGIN";
    add_header X-Content-Type-Options "nosniff";

    try_files $uri $uri/ @bagisto;

    location ~ \.php$ {
        include fastcgi_params;
        fastcgi_pass php;
        fastcgi_param SCRIPT_FILENAME $request_filename;
        fastcgi_param SCRIPT_NAME {{ bagisto_app_url }}/index.php;
        fastcgi_hide_header X-Powered-By;
    }

    location ~* \.(?:jpg|jpeg|gif|png|ico|cur|gz|svg|svgz|mp4|ogg|ogv|webm|htc|webp|woff|woff2)$ {
        try_files $uri @bagisto;
        expires max;
        access_log off;
        add_header Cache-Control "public";
    }

    location ~ /\.(?!well-known).* {
        deny all;
    }
}
{% endif %}

location @bagisto {
    include fastcgi_params;
    fastcgi_pass php;
    fastcgi_param SCRIPT_FILENAME {{ bagisto_abs_path }}/public/index.php;
    fastcgi_param SCRIPT_NAME {{ bagisto_app_url }}/index.php;
    fastcgi_hide_header X-Powered-By;
}

# Livewire AJAX endpoint - Livewire generates absolute /livewire/update URLs
# that fall outside the {{ bagisto_app_url }} subpath location block
location ^~ /livewire {
    include fastcgi_params;
    fastcgi_pass php;
    fastcgi_param SCRIPT_FILENAME {{ bagisto_abs_path }}/public/index.php;
    fastcgi_param SCRIPT_NAME {{ bagisto_app_url }}/index.php;
    fastcgi_hide_header X-Powered-By;
}
