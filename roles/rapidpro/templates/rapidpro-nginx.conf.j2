location = {{ rapidpro_url }} {
    return 301 {{ rapidpro_url }}/;
}

location {{ rapidpro_url }}/static/ {
    alias {{ rapidpro_dir }}/sitestatic/;
}

location {{ rapidpro_url }}/media/ {
    alias {{ rapidpro_dir }}/media/;
}

# Forward /api/v2/ requests to RapidPro (not /api/ — ERPNext uses that)
location /api/v2/ {
    rewrite ^/api/v2/(.*)$ {{ rapidpro_url if rapidpro_url.endswith('/') else rapidpro_url + '/' }}api/v2/$1 break;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header Host $http_host;
    proxy_set_header SCRIPT_NAME {{ rapidpro_url }};
    proxy_pass http://unix:{{ rapidpro_dir }}/run/gunicorn.sock;
}

# Catch-all for RapidPro SPA paths — temba-components constructs URLs
# without the {{ rapidpro_url }} subpath prefix for all these top-level routes
location ~ ^/(flow|contact|msg|ticket|trigger|campaign|org|settings|staff|accounts|relayers|android|c|broadcast|channels|notification|globals|jsi18n|user)/ {
    rewrite ^/(.*)$ {{ rapidpro_url if rapidpro_url.endswith('/') else rapidpro_url + '/' }}$1 break;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header Host $http_host;
    proxy_set_header SCRIPT_NAME {{ rapidpro_url }};
    proxy_pass http://unix:{{ rapidpro_dir }}/run/gunicorn.sock;
}

location {{ rapidpro_url }}/ {
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header Host $http_host;
    proxy_set_header SCRIPT_NAME {{ rapidpro_url }};
    proxy_redirect off;
    proxy_pass http://unix:{{ rapidpro_dir }}/run/gunicorn.sock;
}