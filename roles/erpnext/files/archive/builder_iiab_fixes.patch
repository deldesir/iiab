+			return default
+		return val
+
+	def __getattr__(self, key):
+		return self[key]
+
+	def __call__(self, *args, **kwargs):
+		return SafeDict()
+
+	def __str__(self):
+		return "" if not self else super().__str__()
+
+	def __bool__(self):
+		return len(self) > 0
+
+	def get(self, key, default=None):
+		val = self[key]
+		if isinstance(val, SafeDict) and not val:
+			return default if default is not None else val
+		return val
+
+def safe_call(*args, **kwargs):
