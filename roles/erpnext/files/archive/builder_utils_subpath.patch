+class SafeDict(frappe._dict):
+	def __getitem__(self, key):
+		val = super().get(key)
+		if val is None:
+			return SafeDict()
+		if isinstance(val, dict) and not isinstance(val, SafeDict):
+			return SafeDict(val)
+		return val
+
+	def get(self, key, default=None):
+		val = self.__getitem__(key)
+		if isinstance(val, SafeDict) and not val and default is not None:
+			return default
+		return val
+
+	def __getattr__(self, key):
+		return self[key]
+
+	def __call__(self, *args, **kwargs):
+		return SafeDict()
+
+	def __str__(self):
+		return "" if not self else super().__str__()
+
+	def __bool__(self):
+		return len(self) > 0
+
+	def get(self, key, default=None):
+		val = self[key]
+		if isinstance(val, SafeDict) and not val:
+			return default if default is not None else val
+		return val
+
+def safe_call(*args, **kwargs):
+	res = frappe.call(*args, **kwargs)
+	if res is None:
+		return SafeDict()
+	return res
