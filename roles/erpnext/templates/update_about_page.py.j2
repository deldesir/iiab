import frappe

def run():
    print("Starting database updates...")
    
    # 1. Update Website Settings
    website_settings = frappe.get_doc("Website Settings")
    website_settings.app_name = "Novadah"
    website_settings.brand_html = "<span>Novadah</span>"
    website_settings.head_html = """<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<style>
  :root {
    --font-sans: 'Outfit', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    --primary-accent: #4F46E5;
    --primary-accent-hover: #4338CA;
  }
  body, button, input, select, textarea, p, h1, h2, h3, h4, h5, h6, a, span {
    font-family: var(--font-sans) !important;
  }
  .navbar {
    background: rgba(255, 255, 255, 0.8) !important;
    backdrop-filter: blur(20px) !important;
    -webkit-backdrop-filter: blur(20px) !important;
    border-bottom: 1px solid rgba(0, 0, 0, 0.05) !important;
    box-shadow: 0 4px 30px rgba(0, 0, 0, 0.03) !important;
    padding: 15px 0 !important;
    position: sticky !important;
    top: 0 !important;
    z-index: 1000 !important;
  }
  .navbar-brand {
    font-size: 20px !important;
    font-weight: 700 !important;
    letter-spacing: 0.05em !important;
    color: #0f172a !important;
    text-transform: uppercase !important;
    transition: color 0.3s ease !important;
  }
  .navbar-brand:hover { color: var(--primary-accent) !important; }
  .navbar-nav .nav-link {
    color: #334155 !important;
    font-size: 15px !important;
    font-weight: 500 !important;
    padding: 8px 16px !important;
    transition: all 0.3s ease !important;
    border-radius: 8px !important;
  }
  .navbar-nav .nav-link:hover {
    color: var(--primary-accent) !important;
    background: rgba(79, 70, 229, 0.05) !important;
  }
  .web-footer {
    background: #0f172a !important;
    color: #94a3b8 !important;
    padding: 60px 0 40px 0 !important;
    font-size: 14px !important;
    border-top: 1px solid rgba(255, 255, 255, 0.05) !important;
  }
  .web-footer a {
    color: #cbd5e1 !important;
    transition: color 0.3s ease !important;
    text-decoration: none !important;
  }
  .web-footer a:hover { color: #818cf8 !important; }
  .footer-powered {
    border-top: 1px solid rgba(255, 255, 255, 0.05) !important;
    padding-top: 20px !important;
    margin-top: 20px !important;
  }
  .about-content .hero {
    background: linear-gradient(135deg, rgba(15, 23, 42, 0.95) 0%, rgba(30, 41, 59, 0.9) 100%) !important;
    color: #ffffff !important;
    padding: 80px 40px !important;
    border-radius: 24px !important;
    border: 1px solid rgba(255, 255, 255, 0.05) !important;
    backdrop-filter: blur(24px) !important;
    -webkit-backdrop-filter: blur(24px) !important;
    margin-bottom: 40px !important;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.15) !important;
  }
  .about-content .hero-title {
    font-size: 42px !important;
    font-weight: 800 !important;
    letter-spacing: -0.02em !important;
    margin-bottom: 20px !important;
    color: #ffffff !important;
  }
  .about-content .hero-subtitle p, .about-content .hero-subtitle {
    font-size: 18px !important;
    line-height: 1.6 !important;
    color: rgba(255, 255, 255, 0.85) !important;
  }
</style>"""

    # Set Top Bar items
    website_settings.set("top_bar_items", [
        {"label": "Boutique", "url": "/store"},
        {"label": "Collections", "url": "/collections"},
        {"label": "À propos", "url": "/about"}
    ])
    website_settings.save(ignore_permissions=True)
    print("✓ Updated Website Settings (Navbar items, Brand name, and Premium Stylesheet).")

    # 2. Update About Us Settings (Translate title & company introduction)
    about_settings = frappe.get_doc("About Us Settings")
    about_settings.page_title = "À propos de nous"
    about_settings.company_introduction = """<p>Chez <strong>Novadah Multi-Services</strong>, nous sommes votre partenaire de confiance à Gonaïves pour la technologie, la maison et la mode.</p>
<p>Notre mission est de vous proposer une sélection rigoureuse d'ordinateurs performants, d'appareils électroménagers modernes et de vêtements élégants de qualité supérieure. Nous nous engageons à offrir une expérience d'achat en ligne unique, alliant design moderne, service client exceptionnel et livraison rapide à Gonaïves et dans tout le pays.</p>"""
    about_settings.save(ignore_permissions=True)
    print("✓ Updated About Us Settings (French Title & Company Introduction).")

    # Save and commit database transaction
    frappe.db.commit()
    print("✓ Committed changes to database.")

    # Clear cached website keys
    frappe.cache.delete_value("home_page")
    frappe.cache.delete_value("home_page:Guest")
    print("✓ Cleared web caches.")
    print("Database updates completed successfully!")
