import os

TARGET_DIR = "/home/{{ erpnext_user_name }}/frappe-bench/sites/assets"
SUBPATH = "{{ erpnext_subpath | default('/erp') }}"

# ──────────────────────────────────────────────────────────────────────────────
# POST-BUILD ASSET PATCHER FOR IIAB SUBPATH DEPLOYMENT
# ──────────────────────────────────────────────────────────────────────────────
#
# The deldesir/frappe fork (commit 6c068343d9) handles most subpath routing
# DYNAMICALLY at runtime via:
#   - frappe.router._subpath_prefix  (router.js, request.js, etc.)
#   - iiab_subpath                    (socketio_client.js)
#
# Those runtime-detected patterns MUST NOT be patched here — doing so would
# cause double-prefix bugs like /erp/erp/api/method/ at runtime.
#
# This patcher ONLY handles patterns that cannot be fixed at the JS source
# level: CSS url() references and HTML attributes in compiled bundles that
# point to /assets/ paths.
# ──────────────────────────────────────────────────────────────────────────────

REPLACEMENTS = [
    # CSS url() references to /assets/ — not handled by JS source patches
    ('url("/assets/',  f'url("{SUBPATH}/assets/'),
    ("url('/assets/",  f"url('{SUBPATH}/assets/"),

    # HTML attributes in compiled templates referencing /assets/
    ('src="/assets/',  f'src="{SUBPATH}/assets/'),
    ('href="/assets/', f'href="{SUBPATH}/assets/'),
]

def patch_file(filepath):
    try:
        with open(filepath, "r", encoding="utf-8", errors="ignore") as f:
            content = f.read()

        new_content = content
        for pattern, replacement in REPLACEMENTS:
            new_content = new_content.replace(pattern, replacement)

        # Safety net: collapse any accidental double-prefix
        double_prefix = f"{SUBPATH}{SUBPATH}"
        while double_prefix in new_content:
            new_content = new_content.replace(double_prefix, SUBPATH)

        if new_content != content:
            print(f"Patching {filepath}")
            with open(filepath, "w", encoding="utf-8") as f:
                f.write(new_content)

    except Exception as e:
        print(f"Error patching {filepath}: {e}")

if __name__ == "__main__":
    if not os.path.exists(TARGET_DIR):
        print(f"Target directory {TARGET_DIR} does not exist.")
    else:
        print(f"Scanning {TARGET_DIR} for assets to patch (CSS/HTML asset paths only)...")
        for root, dirs, files in os.walk(TARGET_DIR, followlinks=True):
            # Prune node_modules, bower_components, and hidden directories
            dirs[:] = [d for d in dirs if d not in ('node_modules', 'bower_components') and not d.startswith('.')]
            for name in files:
                # Remove stale compressed files to force Nginx to serve patched versions
                if name.endswith(".gz") or name.endswith(".br"):
                    try:
                        os.remove(os.path.join(root, name))
                    except Exception:
                        pass
                    continue

                # Only patch compiled/minified production assets
                if any(folder in os.path.join(root, name) for folder in ["/dist/", "/pos/", "/builder/", "/webshop/", "/crm/"]):
                    if name.endswith(".js") or name.endswith(".css"):
                        patch_file(os.path.join(root, name))

        print("Patching complete.")
