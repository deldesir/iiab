# ERPNext Subdirectory Nginx Configuration for IIAB
# Mounts ERPNext at /erp/ in accordance with IIAB subpath philosophy.
#
# Design principles:
#   1. All ERPNext traffic goes through /erp/ (primary proxy)
#   2. Root-level locations are scoped as narrowly as possible to avoid
#      conflicts with other IIAB apps sharing the same Nginx server
#   3. sub_filter rewrites HTML-level hard-coded paths so browsers fetch
#      assets/files through /erp/ rather than root
#   4. JS source patches (router.js, socketio_client.js) handle SPA routing

# ── Primary application proxy ──────────────────────────────────────────────────
# Bare /erp/ proxies to Gunicorn root (storefront homepage), while /erp redirects to /erp/
location = /erp {
    return 302 /erp/;
}

location /erp/ {
    # Safety net: handle double-prefixing gracefully
    rewrite ^/erp/erp/(.*) /erp/$1 last;

    rewrite ^/erp/(.*) /$1 break;
    proxy_set_header Accept-Encoding "";
    proxy_pass http://127.0.0.1:8000/;

    proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header X-Frappe-Site-Name {{ erpnext_site_name }};
    proxy_set_header Host              $host;
    proxy_set_header X-Use-X-Accel-Redirect True;

    # Rewrite backend HTTP Location: headers so redirects stay within /erp/
    proxy_redirect /erp/ /erp/;
    proxy_redirect / /erp/;

    proxy_read_timeout 300;

    # ── HTML-level path rewriting ──────────────────────────────────────────
    # Frappe's Python/Jinja templates hard-code root-level paths in HTML.
    # Rewrite them so browsers fetch through /erp/ instead of polluting
    # the root namespace. Only applied to text/html responses (not JS/JSON).
    sub_filter_once off;
    sub_filter_types text/css;
    sub_filter '="/erp/' '="/erp/';
    sub_filter '="/' '="/erp/';
    sub_filter '=\'/erp/' '=\'/erp/';
    sub_filter '=\'/' '=\'/erp/';
    sub_filter 'url("/erp/' 'url("/erp/';
    sub_filter 'url("/' 'url("/erp/';
    sub_filter 'url(\'/erp/' 'url(\'/erp/';
    sub_filter 'url(\'/' 'url(\'/erp/';
    sub_filter 'src=\\"/erp/' 'src=\\"/erp/';
    sub_filter 'src=\\"/' 'src=\\"/erp/';
    sub_filter 'href=\\"/erp/' 'href=\\"/erp/';
    sub_filter 'href=\\"/' 'href=\\"/erp/';
}

# ── Realtime / socket.io ───────────────────────────────────────────────────────
location ^~ /erp/socket.io/ {
    rewrite ^/erp/(.*) /$1 break;
    proxy_pass http://127.0.0.1:9000;

    proxy_http_version 1.1;
    proxy_set_header Upgrade    $http_upgrade;
    proxy_set_header Connection "upgrade";
    proxy_set_header X-Frappe-Site-Name {{ erpnext_site_name }};
    proxy_set_header Origin $scheme://$http_host;
    proxy_set_header Host   $http_host;
}

# ── Static assets ─────────────────────────────────────────────────────────────
# Primary: served via /erp/assets/ (sub_filter rewrites HTML paths here).
location ^~ /erp/assets/ {
    alias /home/{{ erpnext_user_name }}/frappe-bench/sites/assets/;
    try_files $uri =404;
    expires 1y;
    add_header Cache-Control "public, immutable";
}

# Root-level fallbacks: Redirect to /erp/assets/ to keep root clean.
location ^~ /assets/frappe/ { return 301 /erp$request_uri; }
location ^~ /assets/erpnext/ { return 301 /erp$request_uri; }
location ^~ /assets/hrms/ { return 301 /erp$request_uri; }
location ^~ /assets/crm/ { return 301 /erp$request_uri; }
location ^~ /assets/builder/ { return 301 /erp$request_uri; }
location ^~ /assets/webshop/ { return 301 /erp$request_uri; }
location ^~ /assets/pos_next/ { return 301 /erp$request_uri; }
location ^~ /assets/css/ { return 301 /erp$request_uri; }
location ^~ /assets/js/ { return 301 /erp$request_uri; }
location ^~ /assets/locale/ { return 301 /erp$request_uri; }

# ── User-uploaded files ────────────────────────────────────────────────────────
location ^~ /erp/files/ {
    alias /home/{{ erpnext_user_name }}/frappe-bench/sites/{{ erpnext_site_name }}/public/files/;
    try_files $uri =404;
}

# Builder template assets
location ^~ /erp/builder_assets/ {
    alias /home/{{ erpnext_user_name }}/frappe-bench/apps/builder/builder/www/builder_assets/;
    try_files $uri =404;
}

# Root-level /files/ fallback: Redirect to /erp/files/
location ^~ /files/ { return 301 /erp$request_uri; }
location ^~ /builder_assets/ { return 301 /erp$request_uri; }

# Root-level webshop routing redirects
location ^~ /item/ { return 301 /erp$request_uri; }
location ^~ /category/ { return 301 /erp$request_uri; }
location ^~ /categories/ { return 301 /erp$request_uri; }
location = /categories { return 301 /erp/categories; }
location ^~ /collection/ { return 301 /erp$request_uri; }
location ^~ /collections/ { return 301 /erp$request_uri; }
location = /collections { return 301 /erp/collections; }
location ^~ /products/ { return 301 /erp$request_uri; }
location ^~ /shop/ { return 301 /erp$request_uri; }
location = /shop { return 301 /erp/shop; }
location ^~ /cart/ { return 301 /erp$request_uri; }
location = /cart { return 301 /erp/cart; }
location ^~ /checkout/ { return 301 /erp$request_uri; }
location = /checkout { return 301 /erp/checkout; }
location ^~ /orders/ { return 301 /erp$request_uri; }
location = /orders { return 301 /erp/orders; }
location ^~ /wishlist/ { return 301 /erp$request_uri; }
location = /wishlist { return 301 /erp/wishlist; }
location ^~ /me/ { return 301 /erp$request_uri; }
location = /me { return 301 /erp/me; }
location ^~ /profile/ { return 301 /erp$request_uri; }
location = /profile { return 301 /erp/profile; }
location ^~ /blog/ { return 301 /erp$request_uri; }
location = /blog { return 301 /erp/blog; }
location ^~ /about/ { return 301 /erp$request_uri; }
location = /about { return 301 /erp/about; }
location ^~ /contact/ { return 301 /erp$request_uri; }
location = /contact { return 301 /erp/contact; }

# ── Root-level Frappe endpoints (Redirect to /erp/ for subpath consistency) ─────
# These ensure that even if the app produces a root-level link (e.g. /login),
# the browser is immediately bounced back into the /erp/ namespace.

location = /login  { return 307 /erp/login; }
location = /logout { return 307 /erp/logout; }
location = /website_script.js { return 302 /erp/website_script.js; }

# ── Frappe API endpoints ────────────────────────────────────────────────────────
location ^~ /api/method/ {
    return 307 /erp$request_uri;
}
location ^~ /api/resource/ {
    return 307 /erp$request_uri;
}
location ^~ /api/v2/method/ {
    return 307 /erp$request_uri;
}

# ── Bounce-back redirects (SPA navigation safety net) ──────────────────────────
location = /desk  { return 302 /erp/desk; }
location ^~ /desk/ { return 302 /erp$request_uri; }
location = /app   { return 302 /erp/app; }
location ^~ /app/  { return 302 /erp$request_uri; }
location = /apps  { return 307 /erp/apps; }
location ^~ /apps/ { return 307 /erp$request_uri; }
# /hr/ is served by Frappe when hrms is installed — proxy through /erp/ mount
location ^~ /hr/ {
    rewrite ^/hr/(.*) /hr/$1 break;
    proxy_pass http://127.0.0.1:8000;
    proxy_set_header Host               $host;
    proxy_set_header X-Frappe-Site-Name {{ erpnext_site_name }};
}

# ── Frappe CRM standalone SPA ──────────────────────────────────────────────────
# CRM is a separate Vue app served by Frappe at /crm/ via website_route_rules.
# It has its own Vue Router (createWebHistory('/crm')) and talks to /api/method/
# directly (already proxied above). No JS patches required.
location ^~ /crm {
    return 301 /erp$request_uri;
}

# ── Frappe Builder standalone SPA ──────────────────────────────────────────────
# Builder is a separate Vue app served by Frappe at /builder via website_route_rules.
location ^~ /builder {
    return 301 /erp$request_uri;
}

# ── POSNext standalone SPA ─────────────────────────────────────────────────────
# POSNext is a Vue 3 app served by Frappe at /pos via website_route_rules.
location ^~ /pos {
    return 301 /erp$request_uri;
}

# ── Root-level socket.io (Builder/Desk realtime) ──────────────────────────────
# Builder and Desk JS connect to /socket.io/ at the root domain.
# The /erp/socket.io/ block handles requests from the subpath SPA;
# this block handles the root-level requests that bypass the subpath.
location ^~ /socket.io/ {
    proxy_pass http://127.0.0.1:9000;
    proxy_http_version 1.1;
    proxy_set_header Upgrade    $http_upgrade;
    proxy_set_header Connection "upgrade";
    proxy_set_header X-Frappe-Site-Name {{ erpnext_site_name }};
    proxy_set_header Origin $scheme://$http_host;
    proxy_set_header Host   $http_host;
}

# ── Private files (X-Accel-Redirect) ──────────────────────────────────────────
location ~ ^/protected/(.*) {
    internal;
    root /home/{{ erpnext_user_name }}/frappe-bench/sites;
    try_files /{{ erpnext_site_name }}/$1 =404;
}
