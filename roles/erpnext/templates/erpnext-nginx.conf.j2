# ERPNext Subdirectory Nginx Configuration for IIAB
# Prevents Frappe from dominating Port 80, keeping IIAB's box.lan/erpnext structure

location /erpnext/ {
    rewrite ^/erpnext/(.*) /$1 break;
    proxy_pass http://127.0.0.1:8000/;

    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header X-Frappe-Site-Name {{ erpnext_site_name }};
    proxy_set_header Host $host;
    proxy_set_header X-Use-X-Accel-Redirect True;
    proxy_read_timeout 120;
    proxy_redirect off;
}

# Socket.io proxying for realtime events
location /erpnext/socket.io {
    rewrite ^/erpnext/socket.io/(.*) /socket.io/$1 break;
    proxy_pass http://127.0.0.1:9000/socket.io/;

    proxy_http_version 1.1;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection "upgrade";
    proxy_set_header X-Frappe-Site-Name {{ erpnext_site_name }};
    proxy_set_header Origin $scheme://$http_host;
    proxy_set_header Host $http_host;
}

# Serve Frappe's hardcoded root paths from the filesystem
location ^~ /assets/ {
    root /home/frappe/frappe-bench/sites;
    try_files $uri =404;
}

location ^~ /files/ {
    root /home/frappe/frappe-bench/sites/{{ erpnext_site_name }}/public;
    try_files $uri =404;
}

# ERPNext API — only match ERPNext-specific paths (not all /api/)
# This allows SiYuan to handle /api/system/, /api/notebook/, etc. via regex
location ^~ /api/method/ {
    proxy_pass http://127.0.0.1:8000;
    proxy_set_header Host $host;
    proxy_set_header X-Frappe-Site-Name {{ erpnext_site_name }};
}

location ^~ /api/resource/ {
    proxy_pass http://127.0.0.1:8000;
    proxy_set_header Host $host;
    proxy_set_header X-Frappe-Site-Name {{ erpnext_site_name }};
}

# Internal location for X-Accel-Redirect from backend (Private Files)
location ~ ^/protected/(.*) {
    internal;
    root /home/frappe/frappe-bench/sites;
    try_files /{{ erpnext_site_name }}/$1 =404;
}
