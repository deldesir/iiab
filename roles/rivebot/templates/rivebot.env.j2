# RiveBot service environment
# Generated by Ansible — do not edit directly. Edit local_vars.yml instead.

RIVEBOT_PORT={{ rivebot_port }}
RIVEBOT_BRAINS_DIR={{ rivebot_brains_dir }}
RIVEBOT_GATEWAY_URL={{ rivebot_gateway_url }}
RIVEBOT_MACRO_TIMEOUT_S={{ rivebot_macro_timeout_s }}

# SiYuan sync — Mode B (local filesystem)
SIYUAN_DATA_DIR={{ rivebot_siyuan_data_dir }}

# SiYuan sync — Mode C (remote HTTP poll)
SIYUAN_API_URL={{ rivebot_siyuan_api_url }}
SIYUAN_API_TOKEN={{ rivebot_siyuan_api_token }}
SIYUAN_NOTEBOOK_ID={{ rivebot_siyuan_notebook_id }}
SIYUAN_POLL_INTERVAL_S={{ rivebot_siyuan_poll_interval_s }}

# RapidPro API — admin auth gate in macro_bridge.py (ADR-011 Finding 3)
RAPIDPRO_API_URL={{ rivebot_rapidpro_api_url | default('https://garantie.boutique/api/v2') }}
RAPIDPRO_API_TOKEN={{ rapidpro_auth_token }}
