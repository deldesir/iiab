# RiveBot — local reverse proxy (port 8087, internal only)
# Included from the main IIAB nginx config when rivebot_install is true.
# This service is NOT exposed to the internet.

server {
    listen 127.0.0.1:{{ rivebot_port }};
    server_name localhost;

    # Size and timeout tuned for deterministic brain queries (no streaming)
    client_max_body_size 1m;
    proxy_read_timeout 5s;
    proxy_connect_timeout 2s;

    location / {
        proxy_pass http://127.0.0.1:{{ rivebot_port }};
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    }
}
