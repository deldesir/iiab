# email-bridge environment — generated by Ansible from local_vars.yml
# DO NOT EDIT MANUALLY: changes are overwritten on the next role run.

# ── SMTP (outgoing) ──────────────────────────────────────────────────────────
EMAIL_SMTP_HOST={{ email_bridge_smtp_host }}
EMAIL_SMTP_PORT={{ email_bridge_smtp_port }}
EMAIL_SMTP_USER={{ email_bridge_smtp_user }}
EMAIL_SMTP_PASS={{ email_bridge_smtp_pass }}
EMAIL_SMTP_STARTTLS={{ '1' if email_bridge_smtp_starttls | bool else '0' }}
EMAIL_SMTP_SSL={{ '1' if email_bridge_smtp_ssl | bool else '0' }}
EMAIL_FROM={{ email_bridge_from }}
EMAIL_FROM_NAME={{ email_bridge_from_name }}
EMAIL_SUBJECT={{ email_bridge_subject }}

# ── IMAP (incoming, polled) ──────────────────────────────────────────────────
EMAIL_IMAP_HOST={{ email_bridge_imap_host }}
EMAIL_IMAP_PORT={{ email_bridge_imap_port }}
EMAIL_IMAP_USER={{ email_bridge_imap_user }}
EMAIL_IMAP_PASS={{ email_bridge_imap_pass }}
EMAIL_IMAP_FOLDER={{ email_bridge_imap_folder }}
EMAIL_POLL_INTERVAL={{ email_bridge_poll_interval }}
EMAIL_MAX_BODY={{ email_bridge_max_body }}

# ── courier (RapidPro External channel) ──────────────────────────────────────
{% if email_bridge_channel_uuid %}
EMAIL_COURIER_RECEIVE_URL={{ email_bridge_courier_base }}/c/ex/{{ email_bridge_channel_uuid }}/receive
{% endif %}
EMAIL_SEND_AUTH={{ email_bridge_send_auth }}
EMAIL_SENT_TOKEN={{ email_bridge_sent_token }}
