# AI Gateway environment — generated by Ansible from local_vars.yml
# DO NOT EDIT MANUALLY: changes will be overwritten on next Ansible run
# To change settings, edit /etc/iiab/local_vars.yml and re-run:
#   sudo iiab-role ai-gateway

# ── LLM (via litellm proxy) ─────────────────────────────────────────
LLM_MODEL={{ ai_gateway_llm_model }}
LLM_MODEL_SUMMARIZE={{ ai_gateway_llm_model_summarize }}
OPENAI_API_BASE={{ ai_gateway_openai_api_base }}
OPENAI_API_KEY={{ ai_gateway_openai_api_key }}
LLM_TEMPERATURE={{ ai_gateway_llm_temperature | default('0.3') }}

# ── Embeddings ───────────────────────────────────────────────────────
EMBEDDING_PROVIDER={{ ai_gateway_embedding_provider }}
EMBEDDING_MODEL={{ ai_gateway_embedding_model }}

# ── RapidPro integration ─────────────────────────────────────────────
RAPIDPRO_HOST={{ ai_gateway_rapidpro_host }}
RAPIDPRO_API_TOKEN={{ ai_gateway_rapidpro_token }}

# ── SiYuan integration (talkmaster/jwlinker notebook sync) ───────────
SIYUAN_URL={{ ai_gateway_siyuan_url }}
{% if ai_gateway_siyuan_token %}
SIYUAN_API_TOKEN={{ ai_gateway_siyuan_token }}
{% endif %}
# ── Persistence ──────────────────────────────────────────────────────
SQLITE_DB_PATH={{ ai_gateway_dir }}/checkpoints.sqlite
{% if ai_gateway_postgres_uri %}
POSTGRES_URI={{ ai_gateway_postgres_uri }}
{% endif %}

# ── jwlinker ─────────────────────────────────────────────────────────
{% if ai_gateway_jwlinker_db_path %}
JWLINKER_DB_PATH={{ ai_gateway_jwlinker_db_path }}
{% endif %}

# ── Optional ─────────────────────────────────────────────────────────
{% if ai_gateway_admin_phone %}
ADMIN_PHONE={{ ai_gateway_admin_phone }}
{% endif %}
