# Bagisto API Configuration
# NEXT_PUBLIC_BAGISTO_ENDPOINT = full URL of bagisto app (e.g. https://garantie.boutique/live)
NEXT_PUBLIC_BAGISTO_ENDPOINT={{ bagisto_app_url }}
NEXT_PUBLIC_BAGISTO_STOREFRONT_KEY={{ bagisto_headless_storefront_key | default('IIAB_LOCAL_DEPLOYMENT_KEY') }}

# NextAuth Configuration
# NEXTAUTH_URL must be the full base URL (next-auth v4 appends /api/auth internally)
NEXTAUTH_URL={{ bagisto_app_url }}
NEXTAUTH_SECRET={{ bagisto_headless_nextauth_secret | default('iiab-headless-secret-change-in-production') }}
# NEXT_PUBLIC_ prefix required — SessionProvider.basePath must be injected at build time
NEXT_PUBLIC_AUTH_BASEPATH={{ bagisto_subpath }}
NEXT_PUBLIC_NEXT_AUTH_URL={{ bagisto_app_url }}
NEXT_PUBLIC_NEXT_AUTH_SECRET={{ bagisto_headless_nextauth_secret | default('iiab-headless-secret-change-in-production') }}

# Application Settings
COMPANY_NAME=IIAB Edge Commerce

# Internal server-side endpoint (used during SSR/build to bypass nginx loopback)
# Points directly to PHP-FPM via localhost to avoid circular proxy
BAGISTO_INTERNAL_ENDPOINT=http://127.0.0.1

# Subpath prefix for nginx subpath deployment (e.g. /live)
{% set bagisto_subpath = bagisto_app_url | regex_replace('^https?://[^/]+', '') | regex_replace('/$', '') %}
NEXT_BASE_PATH={{ bagisto_subpath }}
